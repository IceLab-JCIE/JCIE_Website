---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { languages, t, type Lang } from "@/lib/i18n";
import { getSite } from "@/lib/data";
import { renderMarkdown } from "@/lib/markdown";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const site = await getSite();

const entries = await getCollection("join");
const entry = entries.find((e) => e.slug === lang);
if (!entry) throw new Error(`Missing join content for lang=${lang}`);

const subject = entry.data.email_subject_template ?? t(lang, "[Join JCIE] Your Name", "[Join JCIE] Your Name");
const label = entry.data.email_button_label ?? t(lang, "发送申请邮件", "Send Application Email");

const email = site.contactEmail ?? "";
const raw = (entry.body ?? "").replaceAll("{{contactEmail}}", email);
const html = renderMarkdown(raw);
---

<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <SectionHeading eyebrow={entry.data.eyebrow ?? t(lang, "加入", "Join")} title={entry.data.title} description={entry.data.description} />

  <article class="card prose" style="margin-top:18px;" set:html={html} />

  <section class="card-muted" style="margin-top:18px;">
    <div class="small muted">
      {lang === "zh"
        ? "快捷申请：点击下方按钮将自动打开邮件客户端。"
        : "Quick apply: the button below opens your email client."}
    </div>
    <div style="margin-top:12px;">
      <a class="btn btn-primary" href={`mailto:${email}?subject=${encodeURIComponent(subject)}`}>{label}</a>
    </div>
  </section>
</BaseLayout>
