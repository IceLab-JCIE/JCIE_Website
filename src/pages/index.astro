---
// Default landing page: redirect to a concrete language route so `/` (and `/JCIE_Website/`)
// doesn't 404 when `base` is configured (e.g. GitHub Pages).
const DEFAULT_LANG = "zh";
const base = import.meta.env.BASE_URL ?? "/";
const baseWithSlash = base.endsWith("/") ? base : `${base}/`;
const targetPath = `${baseWithSlash}${DEFAULT_LANG}/`;
const faviconHref = `${baseWithSlash}favicon.ico`;
---

<!doctype html>
<html lang={DEFAULT_LANG}>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
    <link rel="canonical" href={targetPath} />
    <link rel="icon" href={faviconHref} />
    <title>Redirecting...</title>
  </head>
  <body>
    <a href={targetPath}>Continue</a>
  </body>
</html>
