---
import type { Lang } from "../lib/i18n";
import { t } from "../lib/i18n";
import type { Person, Publication } from "../lib/data";

type Props = {
  person: Person;
  lang: Lang;
  pubIndex: Map<string, Publication>;
};

const { person, lang, pubIndex } = Astro.props;

const name = person.name?.[lang] ?? person.name?.en ?? "";
const dest = person.destination?.[lang] ?? "";
const pubIds = person.pub_ids ?? [];
---

<article class="card card--tint-blue" style="position:relative; overflow:hidden;">
  <div style="position:absolute; right:-56px; top:-56px; width:112px; height:112px; border-radius:999px; background:rgba(11,95,255,0.10); filter:blur(18px);"></div>
  <div style="position:relative;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px;">
      <div style="min-width:0;">
        <h3 style="margin:0; line-height:1.2;">{name}</h3>
        {dest ? (
          <div class="tiny" style="margin-top:8px;">
            <span class="tiny" style="font-weight:650; color:rgba(15,23,42,0.55);">{t(lang, "去向", "Destination")}:</span> {dest}
          </div>
        ) : null}
      </div>
    </div>

    {pubIds.length ? (
      <div style="margin-top:14px; padding-top:14px; border-top:1px solid rgba(15,23,42,0.06);">
        <div style="background:rgba(255,255,255,0.55); border:1px solid rgba(148,163,184,0.28); border-radius:14px; padding:12px;">
          <div class="tiny" style="font-weight:650;">{t(lang, "论文成果", "Publications")}</div>
          <div style="margin-top:10px; display:flex; flex-direction:column; gap:8px;">
            {pubIds.map((id) => {
              const pub = pubIndex.get(id);
              if (!pub) return null;
              const hasLink = Boolean(pub.link && pub.link !== "#");
              return (
                <div style="display:flex; gap:10px; align-items:flex-start; justify-content:space-between;">
                  <div class="small muted" style="min-width:0;">
                    {hasLink ? (
                      <a href={pub.link} target="_blank" rel="noopener noreferrer">{pub.title}</a>
                    ) : (
                      pub.title
                    )}
                  </div>
                  <div style="flex:0 0 auto; display:flex; gap:8px; align-items:center;">
                    {pub.venue ? <span class="badge badge--pub">{pub.venue}</span> : null}
                    {pub.year ? <span class="badge">{pub.year}</span> : null}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    ) : null}
  </div>
</article>

