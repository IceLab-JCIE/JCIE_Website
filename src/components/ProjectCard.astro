---
import type { Lang } from "../lib/i18n";
import { t } from "../lib/i18n";
import type { Project } from "../lib/data";

type Props = { project: Project; lang: Lang };
const { project, lang } = Astro.props;

const title = project.title?.[lang] ?? "";
const summary = project.summary?.[lang] ?? "";
const lead = project.lead?.[lang] ?? "";
const isOngoing = project.status === "ongoing";
const status = t(lang, isOngoing ? "进行中" : "已完成", isOngoing ? "Ongoing" : "Completed");
const hasLink = Boolean(project.github && project.github !== "#");
const badgeClass = isOngoing ? "badge badge--ongoing" : "badge badge--completed";
const area = project.area ?? "";
const areaChipClass =
  area === "EDA" ? "chip chip--blue" : area === "LCA" ? "chip chip--teal" : area ? "chip" : "";
const year = project.start_year ? String(project.start_year) : "";
---

<article class={`card card--tint-${area === "LCA" ? "teal" : "blue"} project-card`}>
  <div class="project-card-top">
    <div class="project-card-badges">
      <span class={badgeClass}>{status}</span>
      {areaChipClass ? <span class={areaChipClass}>{area}</span> : null}
      {year ? <span class="chip">{year}</span> : null}
    </div>
    {hasLink ? (
      <a class="btn btn-ghost project-card-action" href={project.github} target="_blank" rel="noopener noreferrer">
        GitHub
      </a>
    ) : null}
  </div>

  <h3 class="project-card-title">{title}</h3>
  <div class="small muted project-card-summary">{summary}</div>
  {lead ? <div class="tiny project-card-lead">{t(lang, "负责人", "Lead")}: {lead}</div> : null}
</article>
