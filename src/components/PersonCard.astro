---
import type { Lang } from "../lib/i18n";
import { withBase } from "../lib/urls";
import { renderMarkdown } from "../lib/markdown";
import type { Person } from "../lib/data";

type Props = {
  person: Person;
  lang: Lang;
  compact?: boolean;
};

const { person, lang, compact = false } = Astro.props;

const name = person.name?.[lang] ?? person.name?.en ?? "";
const title = person.title?.[lang] ?? person.title?.en ?? "";
const joinYear = person.join_year;
const bio = person.bio?.[lang] ?? "";
const photo = person.photo ? withBase(person.photo.replace(/^\//, "")) : "";

function initialFromName(n: string): string {
  const parts = n.split(/\s+/).filter(Boolean);
  if (parts.length >= 2) return `${parts[0][0] ?? "?"}${parts[1][0] ?? "?"}`.toUpperCase();
  return (parts[0]?.[0] ?? "?").toUpperCase();
}

const initial = initialFromName(name);
const bioHtml = bio ? renderMarkdown(bio) : "";
---

{compact ? (
  <article class="card">
    <div class={`avatar ${photo ? "" : "avatar--placeholder"}`} aria-hidden="true">
      <div class="avatar-inner">
        {photo ? <img src={photo} alt={name} width="56" height="56" loading="lazy" decoding="async" /> : <span class="avatar-text">{initial}</span>}
      </div>
    </div>
    <h3 style="margin:12px 0 0;">{name}</h3>
    {joinYear ? <div class="tiny" style="margin-top:4px;">{joinYear}</div> : null}
  </article>
) : (
  <article class="card">
    <div style="display:flex; gap:14px; align-items:flex-start;">
      <div class={`avatar ${photo ? "" : "avatar--placeholder"}`} aria-hidden="true">
        <div class="avatar-inner">
          {photo ? <img src={photo} alt={name} width="56" height="56" loading="lazy" decoding="async" /> : <span class="avatar-text">{initial}</span>}
        </div>
      </div>
      <div style="flex:1;">
        <h3 style="margin:0;">{name}</h3>
        {title ? <div class="small muted" style="margin-top:4px;">{title}</div> : null}
        {bioHtml ? <div class="prose small" style="margin-top:10px;" set:html={bioHtml} /> : null}
        {joinYear ? <div class="tiny" style="margin-top:10px;">{joinYear}</div> : null}
      </div>
    </div>
  </article>
)}

