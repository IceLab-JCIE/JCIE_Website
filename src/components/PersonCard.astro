---
import type { Lang } from "../lib/i18n";
import { t } from "../lib/i18n";
import { withBase } from "../lib/urls";
import { renderMarkdown } from "../lib/markdown";
import type { Person } from "../lib/data";

type Props = {
  person: Person;
  lang: Lang;
  compact?: boolean;
  mode?: "member" | "detail";
  track?: ("EDA" | "LCA" | string)[] | "EDA" | "LCA" | string;
};

const { person, lang, compact = false, mode, track = "" } = Astro.props;
const effectiveMode: "member" | "detail" = mode ?? (compact ? "member" : "detail");
const trackList = Array.isArray(track) ? track : track ? [track] : [];

const name = person.name?.[lang] ?? person.name?.en ?? "";
const title = person.title?.[lang] ?? person.title?.en ?? "";
const joinYear = person.join_year;
const bio = person.bio?.[lang] ?? "";
const photo = person.photo ? withBase(person.photo.replace(/^\//, "")) : "";

function initialFromName(n: string): string {
  const parts = n.split(/\s+/).filter(Boolean);
  if (parts.length >= 2) return `${parts[0][0] ?? "?"}${parts[1][0] ?? "?"}`.toUpperCase();
  return (parts[0]?.[0] ?? "?").toUpperCase();
}

const initial = initialFromName(name);
const bioHtml = bio ? renderMarkdown(bio) : "";
---

{effectiveMode === "member" ? (
  <article class="card person-card person-card--member">
    <div class="person-card-member-row">
      <div class={`avatar avatar--lg ${photo ? "" : "avatar--placeholder"}`} aria-hidden="true">
        <div class="avatar-inner">
          {photo ? <img src={photo} alt={name} width="72" height="72" loading="lazy" decoding="async" /> : <span class="avatar-text">{initial}</span>}
        </div>
      </div>
      <div class="person-card-body">
        <h3 class="person-card-name">{name}</h3>
        <div class="person-card-meta">
          {trackList.length
            ? trackList.map((x) => (
                <span class={`chip ${x === "EDA" ? "chip--blue" : x === "LCA" ? "chip--teal" : ""}`}>{x}</span>
              ))
            : null}
          {joinYear ? <span class="chip">{t(lang, "加入时间:", "Joined:")} {joinYear}</span> : null}
        </div>
        {title ? <div class="small muted person-card-title">{title}</div> : null}
      </div>
    </div>
  </article>
) : (
  <article class="card person-card person-card--detail">
    <div class="person-card-detail">
      <div class={`avatar avatar--lg ${photo ? "" : "avatar--placeholder"}`} aria-hidden="true">
        <div class="avatar-inner">
          {photo ? <img src={photo} alt={name} width="72" height="72" loading="lazy" decoding="async" /> : <span class="avatar-text">{initial}</span>}
        </div>
      </div>
      <div class="person-card-body">
        <h3 class="person-card-name">{name}</h3>
        {title ? <div class="small muted person-card-title">{title}</div> : null}
        {bioHtml ? <div class="prose small person-card-bio" set:html={bioHtml} /> : null}
        {joinYear ? <div class="tiny person-card-year">{joinYear}</div> : null}
      </div>
    </div>
  </article>
)}
